# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://tudominio.com

# ── MariaDB ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=tu_contraseña
DB_NAME=lab_cotizaciones

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_USER=correo@gmail.com
SMTP_PASS=app_password_generada

# ── Admin panel ───────────────────────────────────────────────────────────────
ADMIN_KEY=cambiar_esta_clave_antes_de_produccion

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Desarrollo: ruta al archivo JSON de la cuenta de servicio
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json
# Producción/Serverless: pegar el contenido completo del JSON como string en una sola línea
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}
SPREADSHEET_ID=1Abc123_tu_spreadsheet_id_aqui

# ── S3 / Almacenamiento de imágenes ───────────────────────────────────────────
# Compatible con AWS S3, Cloudflare R2, DigitalOcean Spaces, MinIO, etc.

S3_REGION=us-east-1
S3_BUCKET=nombre-del-bucket
S3_ACCESS_KEY=tu_access_key
S3_SECRET_KEY=tu_secret_key

# URL pública del bucket o CDN (sin slash al final)
# AWS S3:           https://nombre-del-bucket.s3.us-east-1.amazonaws.com
# Cloudflare R2:    https://tu-id.r2.cloudflarestorage.com  (o dominio custom)
# DigitalOcean:     https://nombre-del-bucket.nyc3.digitaloceanspaces.com
S3_PUBLIC_URL=https://nombre-del-bucket.s3.us-east-1.amazonaws.com

# Solo para servicios S3-compatibles (NO AWS): URL del endpoint
# Cloudflare R2:    https://tu-id.r2.cloudflarestorage.com
# DigitalOcean:     https://nyc3.digitaloceanspaces.com
# MinIO local:      http://localhost:9000
# S3_ENDPOINT=

# true solo para MinIO o servicios que requieren path-style URLs
# S3_FORCE_PATH_STYLE=false
